{
    "base_profile": {
        "merge_source": [ //Lấy shader/material gốc của Minecraft (vanilla) làm nền.
            "vanilla"
        ],
        "include_patterns": [ //Tool sẽ include tất cả file.Tất cả đều được đọc.

            "*"
        ],
        "exclude_patterns": [ //Phần này là loại bỏ file / folder không cần build.
            ".*",
            "_*",
            "include",
            "vanilla"
        ],
        "include_search_paths": [ //những dòng có include
            "include"
        ]
    },
    "profiles": {
    "windows": {
      "platforms": ["Direct3D_SM65"]
    },
    "android": {
      "platforms": ["ESSL_310"]
    },
    "ios": {
      "platforms": ["Metal"]
    }
  }
}
